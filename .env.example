# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/react_starter?schema=public"

# JWT — use a long random string in production (openssl rand -base64 32)
JWT_SECRET="change-me-to-a-secure-random-string"
JWT_EXPIRES_IN="7d"

# Optional seed credentials (defaults shown in README)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="Admin123!"
